# Copy to .env.local and fill in when wiring up a real lead-delivery backend.
# See lib/leadAdapter.ts — none of these are read yet in Phase 1 (leads are
# only logged server-side). Uncomment the block matching whichever backend
# you choose and wire it into submitLead() / submitContactMessage().

# --- Option: Resend (email) ---
# RESEND_API_KEY=
# LEAD_NOTIFICATION_EMAIL=

# --- Option: SendGrid (email) ---
# SENDGRID_API_KEY=
# LEAD_NOTIFICATION_EMAIL=

# --- Option: CRM webhook ---
# CRM_WEBHOOK_URL=

# --- Option: Spreadsheet / Zapier webhook ---
# SHEETS_WEBHOOK_URL=

# --- Analytics (set real IDs in lib/site.ts, not here) ---
# See lib/site.ts: ga4Id, gtmId
